# Postgres — two separate roles on purpose:
#   database_url            — low-privilege runtime role (app_user). Must
#                              NOT be a superuser or BYPASSRLS role, or the
#                              tenant-isolation RLS policies are silently
#                              skipped for every query.
#   migrations_database_url — owner/superuser role, used only by Alembic
#                              to create tables, roles, grants, and RLS
#                              policies. Never used by the running app.
DATABASE_URL=postgresql+psycopg://app_user:CHANGE_ME@localhost:5432/ai_workforce
MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/ai_workforce

JWT_SECRET=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Azure OpenAI (not direct OpenAI — Azure OpenAI is BAA-eligible under
# Microsoft's HIPAA BAA; direct OpenAI's public API is not)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
STT_LANGUAGE=en-IN

# Twilio — requires a signed BAA on your Twilio account for HIPAA scope
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PUBLIC_SERVER_URL=

CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
